MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Render alias (either key works now)
MONGO_URI=
MONGODB_DB_NAME=bitegit
JWT_SECRET=replace_with_long_random_secret
PORT=3000
NODE_ENV=production

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@admin.local
ADMIN_ROLE=SUPER_ADMIN

# Deployment domain/email (used in docs + SSL commands)
DOMAIN=bitegit.com
LETSENCRYPT_EMAIL=admin@bitegit.com

# Optional controls
ADMIN_SESSION_TTL_MINUTES=120
ADMIN_IP_WHITELIST=
ADMIN_FORCE_PASSWORD_SYNC=false
ADMIN_FORCE_ROLE_SYNC=false
ADMIN_FORCE_ACTIVATE=false
ENABLE_DEV_TEST_ROUTES=false

# Keep local Mongo disabled by default (Atlas-first)
ALLOW_LOCAL_MONGO=false

# OTP + Auth email flow
ALLOW_DEMO_OTP=false
SIGNUP_OTP_TTL_MS=600000
AUTH_ACCESS_COOKIE_NAME=bitegit_auth_access
AUTH_REFRESH_COOKIE_NAME=bitegit_auth_refresh

# Modular OTP auth (Node + Express + MySQL + Geetest v4)
AUTH_MYSQL_HOST=
AUTH_MYSQL_PORT=3306
AUTH_MYSQL_USER=
AUTH_MYSQL_PASSWORD=
AUTH_MYSQL_DATABASE=
AUTH_MYSQL_POOL_SIZE=10
AUTH_MYSQL_SSL=false
AUTH_MYSQL_SSL_STRICT=true
GEETEST_CAPTCHA_ID=
GEETEST_CAPTCHA_KEY=
GEETEST_TIMEOUT_MS=10000

# Modular User Center (Node + Express + MySQL)
USER_CENTER_MYSQL_HOST=
USER_CENTER_MYSQL_PORT=3306
USER_CENTER_MYSQL_USER=
USER_CENTER_MYSQL_PASSWORD=
USER_CENTER_MYSQL_DATABASE=
USER_CENTER_MYSQL_POOL_SIZE=10
USER_CENTER_MYSQL_SSL=false
USER_CENTER_MYSQL_SSL_STRICT=true
USER_CENTER_DEFAULT_VIP_LEVEL=Non-VIP
USER_CENTER_RECOVERY_DAYS=50

# Option A: Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND=
MAIL_FROM=
APP_NAME=BITEGIT

# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# Option C: Gmail App Password
GMAIL_USER=
GMAIL_APP_PASSWORD=
